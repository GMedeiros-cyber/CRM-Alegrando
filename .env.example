# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# n8n
# N8N_ZAPI_WEBHOOK_URL: webhook do n8n que recebe eventos da Z-API (Jade/Alegrando)
N8N_ZAPI_WEBHOOK_URL=
# N8N_EVOLUTION_WEBHOOK_URL: webhook do n8n que recebe eventos da Evolution (Márcia/Festas)
# Ex: https://n8n.alegrando.cloud/webhook/evolution-marcia
N8N_EVOLUTION_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Z-Api
# ZAPI_CLIENT_TOKEN: usado tanto pelo sender quanto para validar o header
# `Client-Token` enviado pela Z-API nos webhooks (verifyZapiWebhook).
# Configure o mesmo valor no painel Z-API > Segurança > Token de Webhook.
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Evolution API (Festas - Márcia)
# EVOLUTION_API_KEY: usado tanto para chamadas outbound (sender) quanto para
# validar o header `apikey` enviado pela Evolution nos webhooks (verifyEvolutionWebhook).
EVOLUTION_API_URL=https://evo.alegrando.cloud
EVOLUTION_INSTANCE=Festas
EVOLUTION_API_KEY=

# OpenAI (Gerar Markdown de passeios + embeddings RAG)
OPENAI_API_KEY=

# CRM
ALLOWED_EMAILS=
GOOGLE_REVIEW_LINK=
CRON_SECRET=
